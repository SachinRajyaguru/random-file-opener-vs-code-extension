{
  "name": "random-file-opener",
  "displayName": "Random File Opener",
  "description": "opens a random file",
  "repository": "https://github.com/SachinRajyaguru",
  "version": "17.2.23",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "build": "VERSION=$(node -p \"new Date().toISOString().slice(0, 16).replace(/[-T:]/g, '.')\") && npm run compile && npm run lint"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "publisher": "Sachin",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:openRandomFile",
    "onCommand:stopOpenFile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "randomfileopener.openRandomFile",
        "title": "Random File Opener: Start (default 2s)"
      },
      {
        "command": "randomfileopener.openRandomFilePick",
        "title": "Random File Opener: Start (pick interval)"
      },
      {
        "command": "randomfileopener.stopOpenFile",
        "title": "Random File Opener: Stop"
      }
    ],
    "keybindings": [
      {
        "command": "randomfileopener.openRandomFilePick",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorFocus"
      },
      {
        "command": "randomfileopener.stopOpenFile",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorFocus"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.3",
    "@vscode/test-electron": "^2.2.0"
  },
  "__metadata": {
    "publisherId": "z9dyw73khmgby9hv595w2dhm"
  }
}
